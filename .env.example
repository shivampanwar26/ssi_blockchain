MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/s7_cax6tF0UY7kHOf3DJC

# Private Key for deployment (DO NOT COMMIT THIS!)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PRIVATE_KEY=13958d3a7a4375693b1d7ed73992519beb2a6c2bafc1d22b5e2f9bcf9eb6c746

# Etherscan API Key (for contract verification)
# Get from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=WXZ73CJEUQU5UFIHH3EY4127Y99WJ3DUTP

# Wallet Password (for encrypting agent wallets)
WALLET_PASSWORD=your_secure_password_here

# Gas Reporter (optional)
REPORT_GAS=false
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_for_gas_reporting

# Network Selection
# =================================
# Options: sepolia, localhost, mainnet
BLOCKCHAIN_NETWORK=sepolia

# Application Configuration
# =================================
# Enable/disable blockchain features
USE_BLOCKCHAIN=true
